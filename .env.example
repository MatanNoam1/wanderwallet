# ---- database ----
DATABASE_URL="file:./dev.db"

# ---- auth (Auth.js v5) ----
# generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# Google OAuth client (https://console.cloud.google.com -> Credentials -> OAuth client)
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Public base URL of the app (prod). Local dev defaults to http://localhost:3000
# AUTH_URL="https://wanderwallet.example.com"

# ---- LLM parsing (P2/P3) ----
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ---- Telegram (P2) ----
TELEGRAM_BOT_TOKEN=""
# secret token echoed back by Telegram on every webhook call; we validate it
TELEGRAM_WEBHOOK_SECRET=""

# ---- FX (P1) ----
# Frankfurter (ECB) needs no key; this is the base endpoint, override only to self-host
FX_API_BASE="https://api.frankfurter.app"

# ---- storage / misc ----
UPLOADS_DIR="./uploads"
# HMAC key for signing short-lived image URLs (P5)
IMAGE_SIGNING_KEY=""
